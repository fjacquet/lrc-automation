# Lightroom Classic Catalog Automation - Configuration
# Copy this file to .env and update with your values

# Path to your Lightroom Classic catalog file
LRC_CATALOG_PATH=/path/to/your/catalog.lrcat

# Optional: directory for catalog backups (defaults to same dir as catalog)
LRC_BACKUP_DIR=

# Target folder layout (strftime format, default: %Y/%m/ → YYYY/MM/)
# Examples: %Y/%m/%d/ (YYYY/MM/DD), %Y-%m/ (YYYY-MM), %Y/ (flat yearly)
LRC_TARGET_LAYOUT=%Y/%m/

# Enable GPS-based location subfolders (requires: pip install lrc-automation[geo])
LRC_LOCATION_FOLDERS=false

# Location subfolder ordering (requires LRC_LOCATION_FOLDERS=true)
# Options: month_cc_city (default), cc_city_month, cc_month_city
LRC_LOCATION_ORDER=month_cc_city
